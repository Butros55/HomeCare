# ============================================================================
# HomeCare Planner – Umgebungsvariablen
# Kopieren nach .env und Werte anpassen:  cp .env.example .env
# ============================================================================

# --- Anwendung -------------------------------------------------------------
# Produktname (zentral konfigurierbar, Arbeitsname "HomeCare Planner")
APP_NAME="HomeCare Planner"
NEXT_PUBLIC_APP_NAME="HomeCare Planner"
# Basis-URL der Anwendung (für Links in Einladungen/Benachrichtigungen)
APP_URL="http://localhost:3000"

# --- Datenbank (Docker Compose: user/pass/db = homecare) --------------------
DATABASE_URL="postgresql://homecare:homecare@localhost:5432/homecare?schema=public"
# Für Integrationstests (npm run test:integration)
TEST_DATABASE_URL="postgresql://homecare:homecare@localhost:5432/homecare_test?schema=public"
# Für End-to-End-Tests (npm run test:e2e)
E2E_DATABASE_URL="postgresql://homecare:homecare@localhost:5432/homecare_e2e?schema=public"

# --- Sicherheit -------------------------------------------------------------
# Mind. 32 zufällige Zeichen; wird u. a. als Pepper für Token-Hashes genutzt.
# Erzeugen z. B. mit:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
AUTH_SECRET="dev-only-please-change-me-0123456789abcdef"

# --- Karten & Geocoding & Routing -------------------------------------------
# Provider: mock | nominatim | google
#  - mock:      offline/deterministisch (Tests, Entwicklung ohne Netz)
#  - nominatim: OpenStreetMap, ohne Schlüssel (öffentliche Instanz sparsam nutzen)
#  - google:    Places Autocomplete + Geocoding API (GOOGLE_MAPS_API_KEY nötig)
GEOCODING_PROVIDER="mock"
# Provider: mock | osrm  (Produktion zusätzlich: google | mapbox | ors | graphhopper)
ROUTING_PROVIDER="mock"

# Tile-URL für die Leaflet-Karte. Standard: OSM-Demo-Tiles – NUR für Entwicklung
# geeignet (Nutzungsrichtlinie!). Produktion: eigenen Tile-/Style-Provider setzen.
NEXT_PUBLIC_MAP_TILE_URL="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
NEXT_PUBLIC_MAP_ATTRIBUTION="&copy; OpenStreetMap-Mitwirkende"

# Nominatim (nur wenn GEOCODING_PROVIDER=nominatim; öffentliche Instanz sparsam nutzen)
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
# OSRM (nur wenn ROUTING_PROVIDER=osrm)
OSRM_BASE_URL="https://router.project-osrm.org"

# Produktions-Provider (Schlüssel bleiben ausschließlich serverseitig!)
GOOGLE_MAPS_API_KEY=""
MAPBOX_ACCESS_TOKEN=""
ORS_API_KEY=""
GRAPHHOPPER_API_KEY=""

# --- KI-Priorisierung der Routen-Vorschläge (Ollama Cloud, optional) --------
# Nur der API-Schlüssel ist nötig (https://ollama.com → API Keys). Ohne
# Schlüssel bleibt die KI aus und die regelbasierte Reihenfolge greift.
# Es werden ausschließlich anonymisierte Kennzahlen übertragen – niemals
# Namen, Adressen, Notizen oder Koordinaten.
OLLAMA_API_KEY=""
# Optionale Overrides (Standard: https://ollama.com, gpt-oss:20b, 8000 ms)
# OLLAMA_BASE_URL="https://ollama.com"
# OLLAMA_MODEL="gpt-oss:20b"
# OLLAMA_TIMEOUT_MS="8000"

# --- E-Mail (Dev: "console" loggt Links in das Server-Log) ------------------
MAIL_PROVIDER="console"
MAIL_FROM="noreply@localhost"

# Zusätzliche Dev-Origins (LAN-Zugriff), kommagetrennt
DEV_ALLOWED_ORIGINS=""
